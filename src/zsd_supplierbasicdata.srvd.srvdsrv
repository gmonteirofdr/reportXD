@EndUserText.label: 'Supplier Basic Data - Service Definition'

define service ZSD_SupplierBasicData
  provider contracts odata_v4_ui
{
  expose ZC_SupplierBasicData as SupplierBasicData;
  expose I_Supplier_VH         as SupplierVH;
  expose I_Country             as Country;
  expose I_RegionVH            as RegionVH;
  expose I_SupplierAccountGroup as SupplierAccountGroup;
}
